@model FleetManager.WebMVC.Models.LoginViewModel

@{
    // Магія тут: відключаємо бічне меню та верхню панель для сторінки логіну
    Layout = null;
}

<!DOCTYPE html>
<html lang="uk">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Авторизація - RLP // SYSTEM</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
            body {
                /* Темний індустріальний фон, який пасує до робототехніки */
                background-color: #1e1e2f;
                height: 100vh;
                display: flex;
                align-items: center;
                justify-content: center;
                font-family: 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
            }

            .login-card {
                width: 100%;
                max-width: 420px;
                background: #27293d;
                border-radius: 12px;
                box-shadow: 0 10px 30px rgba(0, 0, 0, 0.5);
                padding: 2.5rem;
                border: 1px solid #344675;
            }

            .brand-header {
                text-align: center;
                margin-bottom: 2rem;
            }

                .brand-header h2 {
                    color: #ffffff;
                    font-weight: 700;
                    letter-spacing: 2px;
                    margin-bottom: 0.5rem;
                }

                .brand-header p {
                    color: #8f8f9d;
                    font-size: 0.9rem;
                }

            .form-label {
                color: #e3e3e3;
                font-weight: 500;
                font-size: 0.9rem;
            }

            .form-control {
                background-color: #1e1e2f;
                border: 1px solid #2b3553;
                color: #ffffff;
                padding: 0.75rem 1rem;
            }

                .form-control:focus {
                    background-color: #1e1e2f;
                    border-color: #e14eca;
                    color: #ffffff;
                    box-shadow: 0 0 0 0.25rem rgba(225, 78, 202, 0.25);
                }

            .btn-login {
                background: linear-gradient(to bottom left, #e14eca, #ba54f5, #e14eca);
                border: none;
                color: white;
                padding: 0.8rem;
                font-weight: 600;
                letter-spacing: 1px;
                transition: transform 0.2s;
            }

                .btn-login:hover {
                    transform: translateY(-2px);
                    color: white;
                    box-shadow: 0 5px 15px rgba(225, 78, 202, 0.4);
                }
    </style>
</head>
<body>

    <div class="login-card">
        <div class="brand-header">
            <h2>RLP // SYSTEM</h2>
            <p>Панель керування флотом</p>
        </div>

        <form asp-controller="Account" asp-action="Login" asp-route-returnUrl="@ViewData["ReturnUrl"]" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3 small fw-bold text-center"></div>
            @if (TempData["ErrorMessage"] != null)
            {
                <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
            }
            @if (TempData["InfoMessage"] != null)
            {
                <div class="alert alert-info">@TempData["InfoMessage"]</div>
            }

            <div class="mb-4">
                <label asp-for="UserName" class="form-label">ЛОГІН</label>
                <input asp-for="UserName" class="form-control" placeholder="admin@fleet.com" autocomplete="off" autofocus />
                <span asp-validation-for="UserName" class="text-danger small mt-1 d-block"></span>
            </div>

            <div class="mb-5">
                <label asp-for="Password" class="form-label">ПАРОЛЬ ДОСТУПУ</label>
                <input asp-for="Password" class="form-control" placeholder="••••••••" />
                <span asp-validation-for="Password" class="text-danger small mt-1 d-block"></span>
            </div>

            <div class="d-grid">
                <button type="submit" class="btn btn-login btn-lg">АВТОРИЗАЦІЯ</button>
            </div>
        </form>
        <div class="mt-3 text-center">
            <form asp-controller="Account" asp-action="SendAdminOneTimePassword" method="post" class="d-inline">
                <input name="email" value="" id="otpEmail" placeholder="Введіть email для одноразового пароля" class="form-control mb-2" />
                <button type="submit" class="btn btn-outline-info btn-sm">Надіслати одноразовий пароль (admin)</button>
            </form>
        </div>
    </div>

</body>
</html>