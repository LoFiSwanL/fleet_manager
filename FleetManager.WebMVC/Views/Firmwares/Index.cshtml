@model IEnumerable<FleetManager.Domain.Models.Firmware>

@{
    ViewData["Title"] = "Index";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="text-accent m-0">Firmware</h4>
    <a asp-action="Create" class="btn btn-outline-success btn-sm font-monospace">+ CREATE NEW</a>
</div>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Version)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.ReleaseDate)
            </th>
            <th>ACTIONS</th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.Version)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.ReleaseDate)
            </td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.Id" class="text-accent text-decoration-none">Edit</a> |
                    <a asp-action="Delete" asp-route-id="@item.Id" class="text-danger text-decoration-none">Delete</a>

                </td>
        </tr>
}
    </tbody>
</table>
