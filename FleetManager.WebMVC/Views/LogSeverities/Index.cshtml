@model IEnumerable<FleetManager.Domain.Models.LogSeverity>

@{
    ViewData["Title"] = "Index";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="text-accent m-0">Severities</h4>
    @if (User.IsInRole("superadmin") || User.IsInRole("admin"))
    {
        <a asp-action="Create" class="btn btn-outline-success btn-sm font-monospace">+ CREATE NEW</a>
    }
</div>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Name)
            </th>
            <th>ACTIONS</th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.Name)
            </td>
                <td>
                    @if (User.IsInRole("superadmin") || User.IsInRole("admin"))
                    {
                        <a asp-action="Edit" asp-route-id="@item.Id" class="text-accent text-decoration-none">Edit</a>
                        <text> | </text>
                        <a asp-action="Delete" asp-route-id="@item.Id" class="text-danger text-decoration-none">Delete</a>
                    }
                    else
                    {
                        <span class="text-muted">No permission</span>
                    }

            </td>
        </tr>
}
    </tbody>
</table>
