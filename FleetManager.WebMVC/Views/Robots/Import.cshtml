@{
    ViewData["Title"] = "Robots import";
}

<h1>Імпорт бази роботів</h1>

<div class="row">
    <div class="col-md-6">
        <div class="card mt-4">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <p class="text-muted mb-0">Формат файлу: .xlsx</p>
    
                    <a asp-action="DownloadTemplate" class="btn btn-sm btn-outline-success">
                        📥 Завантажити порожній шаблон
                    </a>
                </div>
                
                @using (Html.BeginForm("Import", "Robots", FormMethod.Post, new { enctype = "multipart/form-data", id = "frm-excel" }))
                {
                    @if (!ViewData.ModelState.IsValid)
                    {
                        <div class="alert alert-danger mt-3 mb-3">
                            <h5 class="alert-heading">⚠️ Виявлено проблеми у файлі:</h5>
                            <ul class="mb-0">
                                @foreach (var modelState in ViewData.ModelState.Values)
                                {
                                    foreach (var error in modelState.Errors)
                                    {
                                        <li>@error.ErrorMessage</li>
                                    }
                                }
                            </ul>
                        </div>
                    }

                    @if (TempData["SuccessMessage"] != null)
                    {
                        <div class="alert alert-success mt-3 mb-3">
                            @TempData["SuccessMessage"]
                        </div>
                    }
                    <div class="form-group mb-3">
                        <input type="file" name="fileExcel" id="fileExcel" class="form-control" accept=".xlsx" required />
                    </div>
                    <div class="form-group">
                        <div class="form-group mb-4">
                            <label class="form-label fw-bold">Що робити, якщо робот вже існує?</label>
                            <div class="form-check">
                                <input class="form-check-input" type="radio" name="duplicateHandling" id="skip" value="skip" checked>
                                <label class="form-check-label" for="skip">
                                    Пропустити (додати лише нових)
                                </label>
                            </div>
                            <div class="form-check">
                                <input class="form-check-input" type="radio" name="duplicateHandling" id="overwrite" value="overwrite">
                                <label class="form-check-label" for="overwrite">
                                    Оновити дані існуючих роботів
                                </label>
                            </div>
                        </div>
                        <button type="submit" class="btn btn-primary">Завантажити</button>
                        <a asp-action="Index" class="btn btn-outline-secondary">Скасувати</a>
                    </div>
                }
            </div>
        </div>
    </div>
</div>