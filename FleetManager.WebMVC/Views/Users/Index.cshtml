@model IEnumerable<FleetManager.Domain.Models.User>

@{
    ViewData["Title"] = "Operators";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="text-accent m-0">OPERATORS_LIST</h4>
    @if (User.IsInRole("superadmin") || User.IsInRole("admin"))
    {
        <a asp-action="Create" class="btn btn-outline-success btn-sm font-monospace">+ CREATE NEW</a>
    }
</div>

@* ErrorMessage is displayed in the shared layout; remove duplicate here *@

<div class="workspace-card p-3">
    <table class="table table-hover">
        <thead>
            <tr>
                <th>@Html.DisplayNameFor(model => model.UserName)</th>
                <th>@Html.DisplayNameFor(model => model.IsActive)</th>
                <th>@Html.DisplayNameFor(model => model.Role)</th>
                <th>ACTIONS</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@Html.DisplayFor(modelItem => item.UserName)</td>

                    <td>
                        @if (item.UserName != null && item.UserName.ToLower() == "admin")
                        {
                            <span style="color:#00FF41; font-weight:bold;">[ ACTIVE ]</span>
                        }
                        else
                        {
                            <select class="form-select form-select-sm status-dropdown"
                                    data-user-id="@item.Id"
                                    style="background-color: transparent; border: 1px solid var(--border-color); color: @(item.IsActive == true ? "#00FF41" : "#ff4444"); font-weight: bold; width: 120px; cursor: pointer;">
                                @if (item.IsActive == true)
                                {
                                    <option value="true" selected style="color:#00FF41; background-color: #1a1a1a;">[ ACTIVE ]</option>
                                    <option value="false" style="color:#ff4444; background-color: #1a1a1a;">[ OFFLINE ]</option>
                                }
                                else
                                {
                                    <option value="true" style="color:#00FF41; background-color: #1a1a1a;">[ ACTIVE ]</option>
                                    <option value="false" selected style="color:#ff4444; background-color: #1a1a1a;">[ OFFLINE ]</option>
                                }
                            </select>
                        }
                    </td>


                    <td>@Html.DisplayFor(modelItem => item.Role.Name)</td>

                    <td>
                        @if (User.IsInRole("superadmin") || User.IsInRole("admin"))
                        {
                            <a asp-action="Edit" asp-route-id="@item.Id" class="text-accent text-decoration-none">Edit</a>
                        }
                        else
                        {
                            <span class="text-muted">Edit</span>
                        }
                        <text> | </text>
                        <a asp-action="Details" asp-route-id="@item.Id" class="text-info text-decoration-none">Details</a>
                        <text> | </text>
                        @if (User.IsInRole("superadmin") || User.IsInRole("admin"))
                        {
                            if (item.Role != null && item.Role.Name == "superadmin")
                            {
                                <span class="text-muted" title="Protected System Account"><s>Delete</s></span>
                            }
                            else if (User.IsInRole("admin") && item.Role != null && item.Role.Name != "user")
                            {
                                <span class="text-muted" title="No permission"><s>Delete</s></span>
                            }
                            else
                            {
                                <a asp-action="Delete" asp-route-id="@item.Id" class="text-danger text-decoration-none">Delete</a>
                            }
                        }
                        else
                        {
                            <span class="text-muted"><s>Delete</s></span>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>